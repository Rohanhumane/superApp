# API Configuration
API_BASE_URL=https://dev-api.skfinance.com/v1
API_TIMEOUT=30000

# Feature Flags
USE_MOCK_API=true
ENABLE_CRASHLYTICS=false
ENABLE_ANALYTICS=false

# Android Signing (keep in android/local.properties, NOT here)
# RELEASE_STORE_FILE=release.keystore
# RELEASE_KEY_ALIAS=skfinance
# RELEASE_STORE_PASSWORD=<from-vault>
# RELEASE_KEY_PASSWORD=<from-vault>

# Sentry / Crash Reporting
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Firebase (if using)
# FIREBASE_PROJECT_ID=sk-finance-prod
